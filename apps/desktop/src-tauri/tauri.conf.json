{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PhantomMirror",
  "version": "0.1.0",
  "identifier": "dev.phantommirror.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PhantomMirror",
        "width": 1280,
        "height": 820,
        "minWidth": 920,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
